# ========================================
# DOCKERFILE CHO UI (Streamlit Frontend)
# ========================================
# File này hướng dẫn Docker cách build image cho giao diện web
# UI = giao diện người dùng (những gì bạn thấy trên trình duyệt)

# BƯỚC 1: Chọn base image
# Dùng Python 3.10 bản slim (nhẹ, đầy đủ tính năng)
FROM python:3.10-slim

# BƯỚC 2: Tạo thư mục làm việc trong container
# Mọi file sẽ được copy vào đây
WORKDIR /app

# BƯỚC 3: Cấu hình môi trường Python
# PYTHONDONTWRITEBYTECODE: Không tạo file .pyc (giảm rác)
# PYTHONUNBUFFERED: Hiển thị log ngay lập tức (không đợi buffer)
# PYTHONPATH: Cho Python tìm thấy code trong thư mục /app
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

# BƯỚC 4: Cài đặt các thư viện hệ thống cần thiết
# libgl1: Hỗ trợ OpenGL (cần cho OpenCV/PIL xử lý ảnh)
# libglib2.0-0: Thư viện GLib (cần cho nhiều ứng dụng)
# libsm6, libxext6, libxrender-dev: Thư viện X11 (hiển thị ảnh)
# libmagic1, file: Thư viện phát hiện loại file (cho python-magic)
# curl: Dùng để kiểm tra health check
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender-dev \
    libmagic1 \
    file \
    curl \
    && rm -rf /var/lib/apt/lists/*

# BƯỚC 5: Copy file requirements.txt TRƯỚC
# Lý do: Docker cache layer - nếu requirements không đổi,
# Docker sẽ dùng lại layer đã build (nhanh hơn)
COPY myenv/requirements.txt .

# BƯỚC 6: Cài đặt Python packages
# --no-cache-dir: Không lưu cache (giảm dung lượng image)
# --upgrade pip: Đảm bảo pip phiên bản mới nhất
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# BƯỚC 7: Copy code ứng dụng vào container
# Copy theo thứ tự: ít thay đổi -> nhiều thay đổi
# (Tối ưu Docker cache)
COPY myenv/app/ ./app/
COPY myenv/src/ ./src/
COPY myenv/pill_labels.json .
COPY myenv/.env.example .env

# BƯỚC 8: Tạo các thư mục cần thiết
# logs: Lưu log ứng dụng
# data: Lưu dataset ảnh (sẽ mount từ host)
# models: Lưu ML models (sẽ mount từ host)
RUN mkdir -p logs data models

# BƯỚC 9: Mở port 8501
# Streamlit mặc định chạy trên port 8501
# (Chỉ khai báo, chưa expose ra ngoài - docker-compose sẽ làm)
EXPOSE 8501

# BƯỚC 10: Cấu hình health check
# Docker sẽ kiểm tra container có khỏe không mỗi 30 giây
# Nếu fail 3 lần liên tiếp -> container bị restart
# /_stcore/health: Endpoint health check của Streamlit
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8501/_stcore/health || exit 1

# BƯỚC 11: Lệnh chạy khi container start
# streamlit run: Chạy ứng dụng Streamlit
# app/ui.py: File chứa code UI
# --server.port=8501: Chạy trên port 8501
# --server.address=0.0.0.0: Cho phép truy cập từ bên ngoài container
# --server.headless=true: Chạy không cần browser (dành cho server)
CMD ["streamlit", "run", "app/ui.py", "--server.port=8501", "--server.address=0.0.0.0", "--server.headless=true"]